# AuraRoom app settings
APP_NAME=AuraRoom
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# Main loop timing
SAMPLE_INTERVAL_SEC=2.0
INSIGHT_INTERVAL_SEC=15.0
HISTORY_MAX_ITEMS=1800

# Camera / vision
VISION_ENABLED=true
CAMERA_INDEX=0
# Your USB 2.0 UVC board supports 1080p, but defaulting to 640x480 keeps
# YOLO latency stable on Raspberry Pi for live demos. Increase later if needed.
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
CAMERA_FOURCC=MJPG
CAMERA_USE_V4L2=true
YOLO_MODEL_NAME=yolov8n.pt
YOLO_CONF_THRESHOLD=0.35
YOLO_INFER_EVERY_N_FRAMES=10

# Audio
AUDIO_ENABLED=true
AUDIO_SAMPLERATE=16000
AUDIO_BLOCKSIZE=1024
# -1 uses default input device. Set to a concrete index if multiple mics exist.
AUDIO_DEVICE_INDEX=-1
AUDIO_SMOOTHING_ALPHA=0.2
NOISE_LOW_THRESHOLD=0.015
NOISE_HIGH_THRESHOLD=0.08

# Logging backend: jsonl or sqlite
LOG_BACKEND=jsonl
LOG_PATH_JSONL=data/room_events.jsonl
LOG_PATH_SQLITE=data/room_events.db

# Kill switch for anomaly model routing
USE_ML_ANOMALY=true

# Insights: local or llm
INSIGHT_MODE=local
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
